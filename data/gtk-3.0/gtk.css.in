/*
 * This can be customized with:
 * - @sysconfdir@/xfce4/notes.css
 * - ~/.config/gtk-3.0/gtk.css
 * - ~/.config/xfce4/notes/gtk.css
 *
 * If you set $XDG_CONFIG_HOME, replace ~/.config above appropriately.
 */

@define-color notes_theme_base_color @notes_bg_color;
@define-color notes_theme_text_color shade (@notes_theme_base_color, 0.25);
@define-color notes_theme_bg_color @notes_theme_base_color;
@define-color notes_theme_fg_color shade (@notes_theme_base_color, 0.3);
@define-color notes_theme_selected_bg_color shade (@notes_theme_base_color, 0.8);
@define-color notes_theme_selected_fg_color shade (@notes_theme_base_color, 1.4);
@define-color notes_insensitive_bg_color shade (@notes_theme_bg_color, 1.1);
@define-color notes_insensitive_fg_color shade (@notes_theme_fg_color, 1.8);

@define-color notes_borders shade (@notes_theme_base_color, 0.8);
@define-color notes_frame_color shade (@notes_theme_base_color, 0.7);
@define-color notes_notebook_active_tab_border shade (@notes_theme_base_color, 1.1);
@define-color notes_notebook_selected_tab_color shade (@notes_theme_base_color, 0.9);

#notes-window, #notes-window * {
	border-width: 0px;
	-GtkWidget-cursor-aspect-ratio: 0.08;
}

/* window and frame */
window#notes-window frame {
	padding: 1px 2px 4px 2px;
	border: 1px solid shade (@notes_theme_base_color, 0.7);
	background-image: linear-gradient(to bottom,
	                                  shade (@notes_theme_base_color, 0.8),
	                                  shade (@notes_theme_base_color, 0.95) 87px);
}

/* title bar */
#notes-window #titlebar {
	color: black;
	background-color: transparent;
}
#notes-window #titlebar:backdrop {
	color: shade (@notes_insensitive_fg_color, 0.95);
}

/* icon buttons in window title bar */
window#notes-window widget#notes-icon-button:active {
	color: darker (@notes_theme_fg_color);
	text-shadow: 1px 1px lighter (@notes_theme_bg_color);
}
window#notes-window widget#notes-icon-button:disabled {
	color: shade (@notes_insensitive_fg_color, 1.2);
}
window#notes-window widget#notes-icon-button:hover {
	color: shade (@notes_insensitive_fg_color, 0.8);
}

/* notebook */
#notes-window notebook > header, #notes-window notebook arrow {
	background: transparent;
}
#notes-window notebook > header.top {
	border-bottom: 2px solid @notes_theme_selected_bg_color;
}
#notes-window notebook > header.bottom {
	border-top: 2px solid @notes_theme_selected_bg_color;
}
#notes-window notebook > header.left {
	border-right: 2px solid @notes_theme_selected_bg_color;
}
#notes-window notebook > header.right {
	border-left: 2px solid @notes_theme_selected_bg_color;
}

/* notebook tab style */
#notes-window notebook > header.top tab, #notes-window notebook > header.bottom tab {
	padding: 0px 4px;
}
#notes-window notebook > header.right tab, #notes-window notebook > header.left tab {
	padding: 4px 0px;
}

#notes-window notebook > header tab {
	box-shadow: none;
	color: @notes_insensitive_fg_color;
	background: transparent;
}
#notes-window notebook > header tab:checked {
	color: shade (@notes_theme_text_color, 0.8);
}
#notes-window notebook > header tab.dnd {
	background: @notes_theme_selected_bg_color;
}

#notes-window notebook > header.top > tabs > tab:checked {
	box-shadow: inset 0px -3px shade (@notes_theme_selected_bg_color, 1.3), 0px 2px 3px @notes_theme_selected_bg_color;
}
#notes-window notebook > header.top > tabs > tab:checked:hover {
	box-shadow: inset 0px -2px shade (@notes_theme_selected_bg_color, 1.3), 0px 2px 3px @notes_theme_selected_bg_color;
	background: @notes_theme_selected_bg_color; /* NOTE: must be set before .dnd */
}
#notes-window notebook > header.top > tabs > tab:hover {
	box-shadow: inset 0px -2px shade (@notes_theme_selected_bg_color, 1.3);
}

#notes-window notebook > header.bottom > tabs > tab:checked {
	box-shadow: inset 0px 3px shade (@notes_theme_selected_bg_color, 1.3), 0px -2px 3px @notes_theme_selected_bg_color;
}
#notes-window notebook > header.bottom > tabs > tab:checked:hover {
	box-shadow: inset 0px 2px shade (@notes_theme_selected_bg_color, 1.3), 0px -2px 3px @notes_theme_selected_bg_color;
	background: @notes_theme_selected_bg_color;
}
#notes-window notebook > header.bottom > tabs > tab:hover {
	box-shadow: inset 0px 2px shade (@notes_theme_selected_bg_color, 1.3);
}

#notes-window notebook > header.left > tabs > tab:checked {
	box-shadow: inset -3px 0px shade (@notes_theme_selected_bg_color, 1.3), 0px 0px 3px @notes_theme_selected_bg_color;
}
#notes-window notebook > header.left > tabs > tab:checked:hover {
	box-shadow: inset -2px 0px shade (@notes_theme_selected_bg_color, 1.3), 0px 0px 3px @notes_theme_selected_bg_color;
	background: @notes_theme_selected_bg_color;
}
#notes-window notebook > header.left > tabs > tab:hover {
	box-shadow: inset -2px 0px shade (@notes_theme_selected_bg_color, 1.3);
}

#notes-window notebook > header.right > tabs > tab:checked {
	box-shadow: inset 3px 0px shade (@notes_theme_selected_bg_color, 1.3), 0px 0px 3px @notes_theme_selected_bg_color;
}
#notes-window notebook > header.right > tabs > tab:checked:hover {
	box-shadow: inset 2px 0px shade (@notes_theme_selected_bg_color, 1.3), 0px 0px 3px @notes_theme_selected_bg_color;
	background: @notes_theme_selected_bg_color;
}
#notes-window notebook > header.right > tabs > tab:hover {
	box-shadow: inset 2px 0px shade (@notes_theme_selected_bg_color, 1.3);
}

#notes-window textview > text {
	color: @notes_theme_text_color;
	caret-color: @notes_theme_text_color;
	background-color: shade (@notes_theme_bg_color, 1.1);
}

#notes-window textview > text > selection {
	color: @notes_theme_selected_fg_color;
	background-color: @notes_theme_selected_bg_color;
}

#notes-window scrollbar {
	background-color: transparent;
}
#notes-window scrollbar slider {
	background-color: shade (@notes_theme_bg_color, 0.55);
	min-width: 8px;
}
#notes-window scrollbar slider:hover {
	background-color: shade (@notes_theme_bg_color, 0.7);
	transition: 400ms;
}
#notes-window scrollbar slider:hover:active {
	background-color: shade (@notes_theme_bg_color, 0.55);
	transition: 200ms;
}

#notes-window tooltip, #notes-window tooltip * {
	margin: 0px;
	padding: 0px;
}

#notes-window checkbutton * {
	border-width: 1px;
}
